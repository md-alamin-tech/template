<div id="workshop-filters">
  <select id="filter-category">
    <option value="">All Categories</option>
  </select>
  <select id="filter-instructor">
    <option value="">All Instructors</option>
  </select>

  <div id="date-range-wrapper">
    <button id="filter-date-btn" type="button">Filter by Date ▾</button>
    <div id="date-range-panel">
      <div class="date-range-row">
        <label>From</label>
        <input type="date" id="filter-date-from">
      </div>
      <div class="date-range-row">
        <label>To</label>
        <input type="date" id="filter-date-to">
      </div>
      <button id="date-range-clear" type="button">Clear</button>
    </div>
  </div>

  <select id="filter-date">
    <option value="">All Dates</option>
    <option value="upcoming">Upcoming</option>
    <option value="past">Past</option>
  </select>
</div>

<style>
#workshop-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
  position: relative;
}
#workshop-filters select {
  background: transparent;
  color: #ffffff;
  border-radius: 5px;
  font-weight: 500;
  border: 1px solid #ffffff;
  font-family: Inter, sans-serif;
  font-size: 15px;
  padding: 10px 14px;
  height: 42px;
  box-sizing: border-box;
  flex: 0 1 160px;
  appearance: none;
  -webkit-appearance: none;
  -moz-appearance: none;
  cursor: pointer;
}
#workshop-filters select option {
  background: #0a0a0a;
  color: #ffffff;
}

/* Date range button wrapper */
#date-range-wrapper {
  position: relative;
  flex: 0 1 160px;
}
#filter-date-btn {
  width: 100%;
  height: 42px;
  background: transparent;
  color: #ffffff;
  border: 1px solid #ffffff;
  border-radius: 5px;
  font-family: Inter, sans-serif;
  font-size: 15px;
  font-weight: 500;
  padding: 0 14px;
  cursor: pointer;
  box-sizing: border-box;
  text-align: left;
  white-space: nowrap;
}
#filter-date-btn.active {
  border-color: #c8a96e;
  color: #c8a96e;
}

/* Dropdown panel */
#date-range-panel {
  display: none;
  position: absolute;
  top: 48px;
  left: 0;
  background: #0a0a0a;
  border: 1px solid #ffffff;
  border-radius: 5px;
  padding: 14px;
  z-index: 999;
  min-width: 200px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.5);
}
#date-range-panel.open {
  display: block;
}
.date-range-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}
.date-range-row label {
  color: #ffffff;
  font-family: Inter, sans-serif;
  font-size: 13px;
  font-weight: 500;
  width: 32px;
  flex-shrink: 0;
}
.date-range-row input[type="date"] {
  background: transparent;
  color: #ffffff;
  border: 1px solid rgba(255,255,255,0.4);
  border-radius: 4px;
  font-family: Inter, sans-serif;
  font-size: 13px;
  padding: 6px 10px;
  height: 34px;
  box-sizing: border-box;
  flex: 1;
  cursor: pointer;
  color-scheme: dark;
}
.date-range-row input[type="date"]::-webkit-calendar-picker-indicator {
  filter: invert(1);
  cursor: pointer;
}
#date-range-clear {
  width: 100%;
  background: transparent;
  color: rgba(255,255,255,0.5);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 4px;
  font-family: Inter, sans-serif;
  font-size: 12px;
  padding: 5px;
  cursor: pointer;
  margin-top: 2px;
}
#date-range-clear:hover {
  color: #ffffff;
  border-color: #ffffff;
}

@media (max-width: 600px) {
  #workshop-filters {
    flex-direction: column;
  }
  #workshop-filters select,
  #date-range-wrapper {
    flex: 0 0 auto;
    width: 100%;
  }
  #date-range-panel {
    width: 100%;
  }
}
</style>

<script>
(function () {
  function initFilters() {
    var items = document.querySelectorAll('article.blog-item');
    if (!items.length) { setTimeout(initFilters, 300); return; }

    var catSelect = document.getElementById('filter-category');
    var instSelect = document.getElementById('filter-instructor');
    var dateSelect = document.getElementById('filter-date');
    var dateFrom = document.getElementById('filter-date-from');
    var dateTo = document.getElementById('filter-date-to');
    var dateBtn = document.getElementById('filter-date-btn');
    var datePanel = document.getElementById('date-range-panel');
    var clearBtn = document.getElementById('date-range-clear');

    // Toggle panel
    dateBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      datePanel.classList.toggle('open');
    });
    document.addEventListener('click', function (e) {
      if (!datePanel.contains(e.target) && e.target !== dateBtn) {
        datePanel.classList.remove('open');
      }
    });

    // Clear date range
    clearBtn.addEventListener('click', function () {
      dateFrom.value = '';
      dateTo.value = '';
      dateBtn.textContent = 'Filter by Date ▾';
      dateBtn.classList.remove('active');
      applyFilters();
    });

    var categories = new Set();
    var instructors = new Set();
    var today = new Date(); today.setHours(0, 0, 0, 0);

    items.forEach(function (item) {
      var catEl = item.querySelector('.blog-categories');
      var instEl = item.querySelector('.blog-author');
      var dateEl = item.querySelector('time.blog-date');
      if (catEl) categories.add(catEl.textContent.trim());
      if (instEl) instructors.add(instEl.textContent.trim());
      item.dataset.category = catEl ? catEl.textContent.trim() : '';
      item.dataset.instructor = instEl ? instEl.textContent.trim() : '';
      if (dateEl) {
        var iso = dateEl.getAttribute('datetime');
        var d = iso ? new Date(iso) : new Date(dateEl.textContent.trim());
        item.dataset.timeline = (d >= today) ? 'upcoming' : 'past';
        item.dataset.timestamp = d.getTime();
      }
    });

    categories.forEach(function (c) {
      var opt = document.createElement('option');
      opt.value = c; opt.textContent = c;
      catSelect.appendChild(opt);
    });
    instructors.forEach(function (i) {
      var opt = document.createElement('option');
      opt.value = i; opt.textContent = i;
      instSelect.appendChild(opt);
    });

    function applyFilters() {
      var cat = catSelect.value, inst = instSelect.value, date = dateSelect.value;
      var from = dateFrom.value ? new Date(dateFrom.value).getTime() : null;
      var to = dateTo.value ? new Date(dateTo.value).getTime() + 86399999 : null;

      // Update button label
      if (dateFrom.value || dateTo.value) {
        var label = (dateFrom.value || '—') + ' → ' + (dateTo.value || '—');
        dateBtn.textContent = label + ' ▾';
        dateBtn.classList.add('active');
      }

      items.forEach(function (item) {
        var ts = parseInt(item.dataset.timestamp);
        var inRange = (!from && !to) || (
          (!from || ts >= from) &&
          (!to || ts <= to)
        );
        var match =
          (!cat || item.dataset.category === cat) &&
          (!inst || item.dataset.instructor === inst) &&
          (!date || item.dataset.timeline === date) &&
          inRange;
        item.style.display = match ? '' : 'none';
      });
    }

    catSelect.addEventListener('change', applyFilters);
    instSelect.addEventListener('change', applyFilters);
    dateSelect.addEventListener('change', applyFilters);
    dateFrom.addEventListener('change', applyFilters);
    dateTo.addEventListener('change', applyFilters);
  }

  initFilters();
})();
</script>

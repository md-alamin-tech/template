<script>
  (function() {
    var grid = document.getElementById('mimStatsGrid');
    var fired = false;

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !fired) {
          fired = true;
          // Add visible class to fade in stat items
          grid.classList.add('mim-visible');
          // Add spin class to each digit col based on data-spin value
          var cols = grid.querySelectorAll('.mim-digit-col');
          cols.forEach(function(col) {
            var spin = col.getAttribute('data-spin');
            col.classList.add('mim-spin-' + spin);
          });
          observer.disconnect();
        }
      });
    }, { threshold: 0.3 });

    observer.observe(grid);
  })();
</script>
